# ============================================================
# Product Video Pipeline - Environment Variables
# ============================================================

# --- LLM: Reverse Prompt (tu-zi 中转，备选) ---
REVERSE_PROMPT_API_KEY=
REVERSE_PROMPT_BASE_URL=https://api.tu-zi.com/v1
REVERSE_PROMPT_PATH=/chat/completions
REVERSE_PROMPT_MODEL=gemini-3-flash-preview

# --- AI导航 (yswg) 共享配置 ---
AI_NAV_BASE_URL=http://yswg.love:15091/api/admin
AI_NAV_TOKEN=
# 生图/生视频 (GROUP_ID=1)
AI_NAV_IMAGE_APP_ID=2038805674553368579
AI_NAV_IMAGE_GROUP_ID=1
# Gemini-3-flash LLM (GROUP_ID=13)
AI_NAV_LLM_APP_ID=2038805674553368579
AI_NAV_LLM_GROUP_ID=13

# --- Video Generation: Kling AI ---
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v2-5
KLING_MODE=std
KLING_DURATION=5
KLING_ASPECT_RATIO=16:9

# --- Optional ---
HTTPS_PROXY=
LOG_LEVEL=INFO

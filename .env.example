# ============================================================
# Product Video Pipeline - Environment Variables
# ============================================================

# --- LLM: Gemini (Primary) ---
# Service Interface (App-Key auth, polling mode)
GEMINI_SELLPOINT_APP_KEY=
GEMINI_SELLPOINT_APP_SECRET=
GEMINI_SELLPOINT_SERVICE_ID=
GEMINI_SELLPOINT_BASE_URL=
GEMINI_SELLPOINT_POLL_INTERVAL_SEC=3
GEMINI_SELLPOINT_POLL_TIMEOUT_SEC=120

# Proxy Interface (Bearer auth, direct mode)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# --- LLM: DeepSeek / OpenAI (Fallback) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=deepseek-chat

# --- LLM: Reverse Prompt (tu-zi 中转) ---
REVERSE_PROMPT_API_KEY=
REVERSE_PROMPT_BASE_URL=https://api.tu-zi.com/v1
REVERSE_PROMPT_PATH=/chat/completions
REVERSE_PROMPT_MODEL=gemini-3-flash-preview

# --- Image Generation: Gemini ---
# Channel 1 (Nanobanana)
GEMINI_IMAGE_API_KEY=
GEMINI_IMAGE_BASE_URL=
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp

# Channel 2 (Gemini YI)
GEMINI_YI_IMAGE_API_KEY=
GEMINI_YI_IMAGE_BASE_URL=
GEMINI_YI_IMAGE_MODEL=gemini-2.0-flash-exp

# --- Video Generation: Kling AI ---
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v1

# --- Video Analysis: VideoDB ---
VIDEODB_API_KEY=

# --- Compliance Check: Gemini Vision ---
GEMINI_VISION_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-preview-05-20

# --- Optional ---
HTTPS_PROXY=
LOG_LEVEL=INFO
